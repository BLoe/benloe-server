{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": { "@server/*": ["../server/src/*"] }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "../server/src/gateway/sse.ts", "../server/src/gateway/fold.ts"]
}
