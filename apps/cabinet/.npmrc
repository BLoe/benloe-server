# Ambient NODE_ENV=production (set on cabinet-api's own process env, and
# inherited by agent Bash-tool shells) makes npm treat every install as
# `--omit=dev`, silently dropping ALL devDependencies workspace-wide with no
# error — tooling like vitest just isn't there afterward. `include=dev`
# forces devDependencies regardless of ambient NODE_ENV. This MUST live at
# this directory (the true npm workspaces root for server+web) — npm ignores
# a .npmrc placed inside a workspace member dir (server/, web/) entirely.
# See PLATFORM.md, 2026-07-16.
include=dev
